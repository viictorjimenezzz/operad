{
  "name": "@operad/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared React 19 UI for operad's apps/dashboard and apps/studio. Per-algorithm dashboard layouts driven by @json-render.",
  "scripts": {
    "dev:dashboard": "vite --mode dashboard",
    "dev:studio": "vite --mode studio",
    "build:dashboard": "vite build --mode dashboard --outDir dist-dashboard && node ./scripts/finalize-dist.mjs dist-dashboard index.dashboard.html",
    "build:studio": "vite build --mode studio --outDir dist-studio && node ./scripts/finalize-dist.mjs dist-studio index.studio.html",
    "build": "pnpm build:dashboard && pnpm build:studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "clean": "rm -rf dist-dashboard dist-studio node_modules/.vite"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@json-render/core": "^0.1.0",
    "@json-render/react": "^0.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "@xyflow/react": "^12.8.6",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.30.2"
}
