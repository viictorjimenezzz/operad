{
  "algorithm": "AutoResearcher",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "runEvents": { "endpoint": "/runs/$context.runId/events?limit=500" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "plan", "label": "Plan" },
            { "id": "attempts", "label": "Attempts" },
            { "id": "best", "label": "Best answer" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "plan", "attempts", "best", "agents", "events", "graph"]
      },

      "overview": {
        "type": "AutoResearcherDetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.runEvents",
          "sourceChildren": "$queries.children"
        }
      },
      "plan": {
        "type": "AutoResearcherPlanTab",
        "props": {
          "sourceEvents": "$queries.runEvents",
          "sourceChildren": "$queries.children"
        }
      },
      "attempts": {
        "type": "AutoResearcherAttemptsTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children"
        }
      },
      "best": {
        "type": "AutoResearcherBestAnswer",
        "props": { "sourceChildren": "$queries.children" }
      },

      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "hash",
          "extraColumns": ["attempt_index"]
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
