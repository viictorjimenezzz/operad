{
  "algorithm": "Beam",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "candidates", "label": "Candidates" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "candidates", "agents", "events", "graph"]
      },
      "overview": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["overviewSection"]
      },
      "overviewSection": {
        "type": "PanelSection",
        "props": { "label": "Overview" },
        "children": ["overviewGrid"]
      },
      "overviewGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["meta-card", "curve-card"]
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Run", "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },
      "curve-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Algorithm", "title": "convergence", "bodyMinHeight": 240 },
        "children": ["curve"]
      },
      "curve": {
        "type": "ConvergenceCurve",
        "props": { "source": "$queries.iterations", "height": 220 }
      },
      "candidatesSection": {
        "type": "PanelSection",
        "props": { "label": "Candidates" },
        "children": ["progression-card", "candidates-card"]
      },
      "candidates": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["candidatesSection"]
      },
      "progression-card": {
        "type": "PanelCard",
        "props": { "title": "iterations" },
        "children": ["progression"]
      },
      "progression": {
        "type": "IterationProgression",
        "props": { "source": "$queries.iterations" }
      },
      "candidates-card": {
        "type": "PanelCard",
        "props": { "title": "candidate scores", "bodyMinHeight": 240 },
        "children": ["candidates"]
      },
      "candidates": {
        "type": "BeamCandidateChart",
        "props": {
          "source": "$queries.summary.candidates",
          "iterationsSource": "$queries.iterations",
          "height": 240
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
