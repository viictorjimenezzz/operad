{
  "algorithm": "Beam",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "leaderboard", "label": "Leaderboard" },
            { "id": "candidates", "label": "Candidates" },
            { "id": "histogram", "label": "Score distribution" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["leaderboard", "candidates", "histogram", "agents", "events"]
      },
      "leaderboard": {
        "type": "PanelCard",
        "props": { "title": "top-k leaderboard", "bodyMinHeight": 320 },
        "children": ["leaderboard-view"]
      },
      "leaderboard-view": {
        "type": "BeamLeaderboard",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children",
          "runId": "$context.runId"
        }
      },
      "candidates": {
        "type": "PanelCard",
        "props": { "title": "candidates", "bodyMinHeight": 320 },
        "children": ["candidate-chart"]
      },
      "candidate-chart": {
        "type": "BeamCandidateChart",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "height": 320
        }
      },
      "histogram": {
        "type": "PanelCard",
        "props": { "title": "score distribution", "bodyMinHeight": 320 },
        "children": ["histogram-view"]
      },
      "histogram-view": {
        "type": "BeamScoreHistogram",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "bins": 10
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
