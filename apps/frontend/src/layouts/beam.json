{
  "algorithm": "Beam",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "agentsSummary": { "endpoint": "/runs/$context.runId/agents-summary" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "leaderboard", "label": "Leaderboard" },
            { "id": "candidates", "label": "Candidates" },
            { "id": "metrics", "label": "Metrics" },
            {
              "id": "agents",
              "label": "Agents",
              "badge": "$expr:count($queries.agentsSummary.agents)"
            },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["leaderboard", "candidates", "metrics", "agents", "events"]
      },
      "leaderboard": {
        "type": "BeamLeaderboardTab",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children",
          "sourceAgentsSummary": "$queries.agentsSummary",
          "runId": "$context.runId"
        }
      },
      "candidates": {
        "type": "BeamCandidatesTab",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$run.events",
          "sourceChildren": "$queries.children",
          "sourceAgentsSummary": "$queries.agentsSummary",
          "runId": "$context.runId",
          "height": 320
        }
      },
      "metrics": {
        "type": "BeamMetricsTab",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$run.events",
          "sourceChildren": "$queries.children",
          "sourceAgentsSummary": "$queries.agentsSummary"
        }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "mode": "invocations",
          "sourceEvents": "$run.events",
          "sourceAgentsSummary": "$queries.agentsSummary",
          "groupBy": "none"
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
