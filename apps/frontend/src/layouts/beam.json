{
  "algorithm": "Beam",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "candidates", "label": "candidates" },
            { "id": "graph", "label": "graph" },
            { "id": "events", "label": "events" }
          ]
        },
        "children": ["t-candidates", "t-graph", "t-events"]
      },
      "t-candidates": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["overviewSection", "candidatesSection"]
      },
      "overviewSection": {
        "type": "PanelSection",
        "props": { "label": "Overview" },
        "children": ["overviewGrid"]
      },
      "overviewGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["meta-card", "curve-card"]
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Run", "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },
      "curve-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Algorithm", "title": "convergence", "bodyMinHeight": 240 },
        "children": ["curve"]
      },
      "curve": {
        "type": "ConvergenceCurve",
        "props": { "source": "$queries.iterations", "height": 220 }
      },
      "candidatesSection": {
        "type": "PanelSection",
        "props": { "label": "Candidates" },
        "children": ["progression-card", "candidates-card"]
      },
      "progression-card": {
        "type": "PanelCard",
        "props": { "title": "iterations" },
        "children": ["progression"]
      },
      "progression": {
        "type": "IterationProgression",
        "props": { "source": "$queries.iterations" }
      },
      "candidates-card": {
        "type": "PanelCard",
        "props": { "title": "candidate scores", "bodyMinHeight": 240 },
        "children": ["candidates"]
      },
      "candidates": {
        "type": "BeamCandidateChart",
        "props": {
          "source": "$queries.summary.candidates",
          "iterationsSource": "$queries.iterations",
          "height": 240
        }
      },
      "t-graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph"]
      },
      "graph": { "type": "AgentGraph", "props": { "source": "$queries.graph" } },
      "t-events": { "type": "EventTimeline", "props": { "source": "$run.events" } }
    }
  }
}
