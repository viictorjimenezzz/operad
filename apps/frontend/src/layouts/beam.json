{
  "algorithm": "Beam",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "candidates", "label": "Candidates" },
            { "id": "histogram", "label": "Histogram" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "candidates", "histogram", "agents", "events", "graph"]
      },
      "overview": {
        "type": "BeamDetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children"
        }
      },
      "candidates": {
        "type": "PanelCard",
        "props": { "title": "candidate leaderboard", "bodyMinHeight": 320 },
        "children": ["candidate-leaderboard"]
      },
      "candidate-leaderboard": {
        "type": "BeamLeaderboard",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children",
          "runId": "$context.runId"
        }
      },
      "histogram": {
        "type": "PanelCard",
        "props": { "title": "score distribution", "bodyMinHeight": 320 },
        "children": ["histogram-view"]
      },
      "histogram-view": {
        "type": "BeamScoreHistogram",
        "props": {
          "source": "$queries.summary.candidates",
          "sourceIterations": "$queries.iterations"
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
