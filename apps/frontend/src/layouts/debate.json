{
  "algorithm": "Debate",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "debate": {
      "endpoint": "/runs/$context.runId/debate.json",
      "stream": "/runs/$context.runId/debate.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "rounds", "label": "Rounds" },
            { "id": "transcript", "label": "Transcript" },
            { "id": "consensus", "label": "Consensus" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["rounds", "transcript", "consensus", "agents", "events"]
      },
      "rounds": {
        "type": "PanelCard",
        "props": { "title": "round-by-round scoring", "bodyMinHeight": 320 },
        "children": ["rounds-view"]
      },
      "rounds-view": {
        "type": "DebateRoundView",
        "props": { "source": "$queries.debate" }
      },
      "transcript": {
        "type": "PanelCard",
        "props": { "title": "transcript by round", "bodyMinHeight": 320 },
        "children": ["transcript-view"]
      },
      "transcript-view": {
        "type": "DebateTranscript",
        "props": { "source": "$queries.debate" }
      },
      "consensus": {
        "type": "PanelCard",
        "props": { "title": "consensus arc", "bodyMinHeight": 320 },
        "children": ["consensus-view"]
      },
      "consensus-view": {
        "type": "DebateConsensusTracker",
        "props": { "source": "$queries.debate", "height": 300 }
      },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId", "groupBy": "hash" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
