{
  "algorithm": "Debate",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "debate": {
      "endpoint": "/runs/$context.runId/debate.json",
      "stream": "/runs/$context.runId/debate.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "transcript", "label": "Transcript" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "transcript", "agents", "events", "graph"]
      },

      "overview": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["overviewSection"]
      },
      "overviewSection": {
        "type": "PanelSection",
        "props": { "label": "Overview" },
        "children": ["overviewGrid"]
      },
      "overviewGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["meta-card", "rounds-card", "consensus-card"]
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },
      "rounds-card": {
        "type": "PanelCard",
        "props": { "title": "round scores" },
        "children": ["rounds"]
      },
      "rounds": {
        "type": "DebateRoundView",
        "props": { "source": "$queries.summary.rounds" }
      },
      "consensus-card": {
        "type": "PanelCard",
        "props": { "title": "consensus over rounds" },
        "children": ["consensus"]
      },
      "consensus": {
        "type": "DebateConsensusTracker",
        "props": { "source": "$queries.debate" }
      },

      "transcript": {
        "type": "PanelCard",
        "props": { "title": "transcript" },
        "children": ["transcript-view"]
      },
      "transcript-view": {
        "type": "DebateTranscript",
        "props": { "source": "$queries.debate" }
      },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
