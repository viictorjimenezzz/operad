{
  "algorithm": "EvoGradient",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "fitness": {
      "endpoint": "/runs/$context.runId/fitness.json",
      "stream": "/runs/$context.runId/fitness.sse"
    },
    "mutations": {
      "endpoint": "/runs/$context.runId/mutations.json",
      "stream": "/runs/$context.runId/mutations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "evolution", "label": "Evolution" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "evolution", "agents", "events", "graph"]
      },
      "overview": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["kpiSection", "fitnessSection"]
      },
      "kpiSection": {
        "type": "PanelSection",
        "props": { "label": "Summary" },
        "children": ["kpis"]
      },
      "kpis": {
        "type": "PanelGrid",
        "props": { "cols": 4, "gap": "md" },
        "children": ["k-events-card", "k-tokens-card", "k-cost-card", "k-score-card"]
      },
      "k-events-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Events", "surface": "inset", "bare": true },
        "children": ["k-events"]
      },
      "k-events": {
        "type": "KPI",
        "props": { "label": "events", "source": "$queries.summary.event_total", "format": "int" }
      },
      "k-tokens-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Tokens", "surface": "inset", "bare": true },
        "children": ["k-tokens"]
      },
      "k-tokens": {
        "type": "KPI",
        "props": {
          "label": "tokens",
          "source": "$queries.summary.prompt_tokens",
          "format": "tokens"
        }
      },
      "k-cost-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Cost", "surface": "inset", "bare": true },
        "children": ["k-cost"]
      },
      "k-cost": {
        "type": "KPI",
        "props": { "label": "cost", "source": "$queries.summary.cost.cost_usd", "format": "cost" }
      },
      "k-score-card": {
        "type": "PanelCard",
        "props": { "eyebrow": "Best", "surface": "inset", "bare": true },
        "children": ["k-score"]
      },
      "k-score": {
        "type": "KPI",
        "props": {
          "label": "best",
          "source": "$queries.summary.algorithm_terminal_score",
          "format": "number"
        }
      },
      "fitnessSection": {
        "type": "PanelSection",
        "props": { "label": "Fitness" },
        "children": ["fitnessGrid"]
      },
      "fitnessGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["fitness-card", "meta-card"]
      },
      "fitness-card": {
        "type": "PanelCard",
        "props": { "title": "fitness", "bodyMinHeight": 260 },
        "children": ["fitness"]
      },
      "fitness": {
        "type": "FitnessCurve",
        "props": { "source": "$queries.fitness", "height": 240 }
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },

      "evolution": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["popSection", "opsSection"]
      },
      "popSection": {
        "type": "PanelSection",
        "props": { "label": "Population" },
        "children": ["scatter-card"]
      },
      "scatter-card": {
        "type": "PanelCard",
        "props": { "title": "population", "bodyMinHeight": 240 },
        "children": ["scatter"]
      },
      "scatter": {
        "type": "PopulationScatter",
        "props": { "source": "$queries.fitness", "height": 220 }
      },
      "opsSection": {
        "type": "PanelSection",
        "props": { "label": "Mutation operators" },
        "children": ["opsGrid"]
      },
      "opsGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["ops-card", "heat-card"]
      },
      "ops-card": {
        "type": "PanelCard",
        "props": { "title": "operator success" },
        "children": ["ops-table"]
      },
      "ops-table": { "type": "OpSuccessTable", "props": { "source": "$queries.mutations" } },
      "heat-card": {
        "type": "PanelCard",
        "props": { "title": "per-op success rate per generation" },
        "children": ["heat"]
      },
      "heat": { "type": "MutationHeatmap", "props": { "source": "$queries.mutations" } },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": {
        "type": "AgentGraph",
        "props": { "source": "$queries.graph", "sourceMutations": "$queries.mutations" }
      }
    }
  }
}
