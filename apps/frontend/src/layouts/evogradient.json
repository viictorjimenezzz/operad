{
  "algorithm": "EvoGradient",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "fitness": {
      "endpoint": "/runs/$context.runId/fitness.json",
      "stream": "/runs/$context.runId/fitness.sse"
    },
    "mutations": {
      "endpoint": "/runs/$context.runId/mutations.json",
      "stream": "/runs/$context.runId/mutations.sse"
    },
    "events": { "endpoint": "/runs/$context.runId/events?limit=1000" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "evolution", "label": "Evolution" },
            { "id": "population", "label": "Population" },
            { "id": "operators", "label": "Operators" },
            { "id": "lineage", "label": "Lineage" },
            { "id": "best-diff", "label": "Best diff" },
            { "id": "parameters", "label": "Parameters" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": [
          "overview",
          "evolution",
          "population",
          "operators",
          "lineage",
          "best-diff",
          "parameters",
          "agents",
          "events",
          "graph"
        ]
      },
      "overview": {
        "type": "EvoDetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceFitness": "$queries.fitness",
          "sourceMutations": "$queries.mutations",
          "sourceEvents": "$queries.events"
        }
      },
      "evolution": {
        "type": "EvoEvolutionTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceFitness": "$queries.fitness",
          "sourceEvents": "$queries.events"
        }
      },
      "population": {
        "type": "EvoPopulationTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceFitness": "$queries.fitness",
          "sourceEvents": "$queries.events"
        }
      },
      "operators": {
        "type": "EvoOperatorsTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceMutations": "$queries.mutations",
          "sourceEvents": "$queries.events"
        }
      },
      "lineage": {
        "type": "EvoLineageTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceFitness": "$queries.fitness",
          "sourceEvents": "$queries.events"
        }
      },
      "best-diff": {
        "type": "EvoBestDiffTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceFitness": "$queries.fitness",
          "sourceEvents": "$queries.events"
        }
      },
      "parameters": {
        "type": "ParametersTab",
        "props": { "runId": "$context.runId", "scope": "run" }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "hash",
          "extraColumns": ["gen", "individual_id"]
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": {
        "type": "AgentGraph",
        "props": {
          "source": "$queries.graph",
          "sourceMutations": "$queries.mutations"
        }
      }
    }
  }
}
