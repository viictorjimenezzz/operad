{
  "algorithm": "OPRO",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "iterations", "label": "Iterations" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "iterations", "agents", "events", "graph"]
      },
      "overview": {
        "type": "PanelCard",
        "props": {
          "title": "OPRO overview",
          "bodyMinHeight": 220
        },
        "children": ["overview-empty"]
      },
      "overview-empty": {
        "type": "EmptyState",
        "props": {
          "title": "overview pending",
          "description": "OPRO-specific panels are owned by Brief 16"
        }
      },
      "iterations": {
        "type": "PanelCard",
        "props": { "title": "optimizer iterations", "bodyMinHeight": 320 },
        "children": ["iterations-empty"]
      },
      "iterations-empty": {
        "type": "EmptyState",
        "props": {
          "title": "iteration view pending",
          "description": "candidate proposal and evaluation panels are owned by Brief 16"
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
