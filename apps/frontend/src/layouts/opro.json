{
  "algorithm": "OPRO",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": { "endpoint": "/runs/$context.runId/iterations.json" },
    "events": { "endpoint": "/runs/$context.runId/events?limit=500" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "history", "label": "History" },
            { "id": "candidates", "label": "Candidates" },
            { "id": "parameter", "label": "Parameter" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "history", "candidates", "parameter", "agents", "events", "graph"]
      },
      "overview": {
        "type": "OPRODetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events",
          "sourceChildren": "$queries.children",
          "runId": "$context.runId"
        }
      },
      "history": {
        "type": "OPROHistoryTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events",
          "sourceChildren": "$queries.children"
        }
      },
      "candidates": {
        "type": "OPROCandidatesTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events",
          "sourceChildren": "$queries.children",
          "runId": "$context.runId"
        }
      },
      "parameter": {
        "type": "OPROParameterTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events",
          "sourceChildren": "$queries.children"
        }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "hash",
          "emptyTitle": "no OPRO child agents yet",
          "emptyDescription": "proposer and evaluator child runs appear after OPRO emits synthetic invocations"
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
