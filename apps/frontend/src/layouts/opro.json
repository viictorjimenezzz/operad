{
  "algorithm": "OPRO",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": { "endpoint": "/runs/$context.runId/iterations.json" },
    "events": { "endpoint": "/runs/$context.runId/events?limit=500" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "agentsSummary": { "endpoint": "/runs/$context.runId/agents-summary" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "history", "label": "Prompt history" },
            { "id": "score", "label": "Score curve" },
            { "id": "parameters", "label": "Parameters" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.agentsSummary.agents)", "condition": "$expr:count($queries.agentsSummary.agents)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["history", "score", "parameters", "agents", "events"]
      },
      "history": {
        "type": "OPROPromptHistoryTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events"
        }
      },
      "score": {
        "type": "OPROScoreCurveTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "sourceEvents": "$queries.events"
        }
      },
      "parameters": {
        "type": "ParametersTab",
        "props": { "runId": "$context.runId", "scope": "run" }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "hash",
          "emptyTitle": "no OPRO child agents yet",
          "emptyDescription": "proposer and evaluator child runs appear after OPRO emits synthetic invocations"
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
