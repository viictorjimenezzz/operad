{
  "algorithm": "SelfRefine",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "agentsSummary": { "endpoint": "/runs/$context.runId/agents-summary" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "ladder", "label": "Refine ladder" },
            { "id": "iterations", "label": "Iterations" },
            { "id": "parameters", "label": "Parameters" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.agentsSummary.agents)", "condition": "$expr:count($queries.agentsSummary.agents)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["ladder", "iterations", "parameters", "agents", "events"]
      },
      "ladder": {
        "type": "SelfRefineLadderTab",
        "props": {
          "sourceIterations": "$queries.iterations"
        }
      },
      "iterations": {
        "type": "SelfRefineIterationsTab",
        "props": {
          "sourceIterations": "$queries.iterations",
          "runId": "$context.runId"
        }
      },
      "parameters": {
        "type": "ParametersTab",
        "props": { "runId": "$context.runId", "scope": "run" }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "hash"
        }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
