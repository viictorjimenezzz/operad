{
  "algorithm": "SelfRefine",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "iterations", "label": "Iterations" },
            { "id": "convergence", "label": "Convergence" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "iterations", "convergence", "agents", "events", "graph"]
      },

      "overview": {
        "type": "SelfRefineDetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceIterations": "$queries.iterations",
          "sourceChildren": "$queries.children"
        }
      },
      "iterations": {
        "type": "IterationLadder",
        "props": {
          "source": "$queries.iterations",
          "sourceChildren": "$queries.children"
        }
      },
      "convergence": {
        "type": "PanelCard",
        "props": { "title": "convergence", "bodyMinHeight": 320 },
        "children": ["convergence-view"]
      },
      "convergence-view": {
        "type": "SelfRefineConvergence",
        "props": { "source": "$queries.iterations", "height": 300 }
      },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId", "groupBy": "hash" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
