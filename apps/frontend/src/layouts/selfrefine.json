{
  "algorithm": "SelfRefine",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "iterations": {
      "endpoint": "/runs/$context.runId/iterations.json",
      "stream": "/runs/$context.runId/iterations.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "refinements", "label": "Refinements" },
            { "id": "reflections", "label": "Reflections" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "refinements", "reflections", "agents", "events", "graph"]
      },

      "overview": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["section"]
      },
      "section": {
        "type": "PanelSection",
        "props": { "label": "Overview" },
        "children": ["grid"]
      },
      "grid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["meta-card", "curve-card", "progression-card"]
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },
      "curve-card": {
        "type": "PanelCard",
        "props": { "title": "convergence", "bodyMinHeight": 260 },
        "children": ["curve"]
      },
      "curve": {
        "type": "ConvergenceCurve",
        "props": { "source": "$queries.iterations", "height": 240 }
      },
      "progression-card": {
        "type": "PanelCard",
        "props": { "title": "iterations" },
        "children": ["progression"]
      },
      "progression": {
        "type": "IterationProgression",
        "props": { "source": "$queries.iterations" }
      },

      "refinements": {
        "type": "PanelCard",
        "props": { "title": "refine cycles" },
        "children": ["refinements-view"]
      },
      "refinements-view": {
        "type": "IterationProgression",
        "props": { "source": "$queries.iterations", "phaseFilter": "refine", "showDiff": true }
      },

      "reflections": {
        "type": "PanelCard",
        "props": { "title": "reflection critiques" },
        "children": ["reflections-view"]
      },
      "reflections-view": {
        "type": "IterationProgression",
        "props": { "source": "$queries.iterations", "phaseFilter": "reflect" }
      },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
