{
  "algorithm": "Sweep",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "sweep": {
      "endpoint": "/runs/$context.runId/sweep.json",
      "stream": "/runs/$context.runId/sweep.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "heatmap", "label": "Heatmap" },
            { "id": "cells", "label": "Cells" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "heatmap", "cells", "agents", "events", "graph"]
      },

      "overview": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["kpiSection", "bestSection"]
      },
      "kpiSection": {
        "type": "PanelSection",
        "props": { "label": "Summary" },
        "children": ["kpis"]
      },
      "kpis": {
        "type": "PanelGrid",
        "props": { "cols": 4, "gap": "md" },
        "children": ["k-events", "k-tokens", "k-cost", "k-best"]
      },
      "k-events": {
        "type": "PanelCard",
        "props": { "eyebrow": "Events", "surface": "inset", "bare": true },
        "children": ["k-events-stat"]
      },
      "k-events-stat": {
        "type": "StatTile",
        "props": { "label": "events", "value": 0, "size": "sm" }
      },
      "k-tokens": {
        "type": "PanelCard",
        "props": { "eyebrow": "Tokens", "surface": "inset", "bare": true },
        "children": ["k-tokens-stat"]
      },
      "k-tokens-stat": {
        "type": "KPI",
        "props": {
          "label": "tokens",
          "source": "$queries.summary.prompt_tokens",
          "format": "tokens"
        }
      },
      "k-cost": {
        "type": "PanelCard",
        "props": { "eyebrow": "Cost", "surface": "inset", "bare": true },
        "children": ["k-cost-stat"]
      },
      "k-cost-stat": {
        "type": "KPI",
        "props": { "label": "cost", "source": "$queries.summary.cost.cost_usd", "format": "cost" }
      },
      "k-best": {
        "type": "PanelCard",
        "props": { "eyebrow": "Best", "surface": "inset", "bare": true },
        "children": ["k-best-stat"]
      },
      "k-best-stat": {
        "type": "KPI",
        "props": {
          "label": "score",
          "source": "$queries.summary.algorithm_terminal_score",
          "format": "number"
        }
      },

      "bestSection": {
        "type": "PanelSection",
        "props": { "label": "Sweep" },
        "children": ["bestGrid"]
      },
      "bestGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["best-card", "cost-card"]
      },
      "best-card": {
        "type": "PanelCard",
        "props": { "title": "best cell" },
        "children": ["best-cell"]
      },
      "best-cell": { "type": "SweepBestCellCard", "props": { "source": "$queries.sweep" } },
      "cost-card": {
        "type": "PanelCard",
        "props": { "title": "cell progress" },
        "children": ["cost-total"]
      },
      "cost-total": { "type": "SweepCostTotalizer", "props": { "source": "$queries.sweep" } },

      "heatmap": {
        "type": "PanelCard",
        "props": { "title": "parameter grid", "bodyMinHeight": 320 },
        "children": ["heatmap-view"]
      },
      "heatmap-view": { "type": "SweepHeatmap", "props": { "source": "$queries.sweep" } },

      "cells": {
        "type": "PanelCard",
        "props": { "title": "all cells" },
        "children": ["cells-timeline"]
      },
      "cells-timeline": {
        "type": "EventsTab",
        "props": { "runId": "$context.runId", "defaultKindFilter": ["cell"] }
      },

      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "none",
          "extraColumns": ["axisValues", "score"]
        }
      },
      "events": {
        "type": "EventsTab",
        "props": { "runId": "$context.runId", "defaultKindFilter": ["cell"] }
      },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
