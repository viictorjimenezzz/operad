{
  "algorithm": "Sweep",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "sweep": {
      "endpoint": "/runs/$context.runId/sweep.json",
      "stream": "/runs/$context.runId/sweep.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "heatmap", "label": "Heatmap" },
            { "id": "cells", "label": "Cells" },
            { "id": "parallel", "label": "Parallel coords" },
            { "id": "cost", "label": "Cost" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["overview", "heatmap", "cells", "parallel", "cost", "agents", "events"]
      },
      "overview": {
        "type": "SweepDetailOverview",
        "props": {
          "source": "$queries.sweep",
          "sourceSummary": "$queries.summary",
          "sourceChildren": "$queries.children"
        }
      },
      "heatmap": {
        "type": "SweepHeatmapTab",
        "props": { "source": "$queries.sweep", "sourceChildren": "$queries.children" }
      },
      "cells": {
        "type": "SweepCellsTab",
        "props": {
          "source": "$queries.sweep",
          "sourceChildren": "$queries.children",
          "runId": "$context.runId"
        }
      },
      "parallel": {
        "type": "SweepParallelCoordsTab",
        "props": {
          "source": "$queries.sweep",
          "sourceChildren": "$queries.children"
        }
      },
      "cost": {
        "type": "SweepCostTab",
        "props": { "source": "$queries.sweep", "sourceChildren": "$queries.children" }
      },
      "agents": {
        "type": "AgentsTab",
        "props": {
          "runId": "$context.runId",
          "groupBy": "none",
          "extraColumns": ["axisValues", "score"]
        }
      },
      "events": {
        "type": "EventsTab",
        "props": { "runId": "$context.runId", "defaultKindFilter": ["cell"] }
      }
    }
  }
}
