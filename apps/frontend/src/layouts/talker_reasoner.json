{
  "algorithm": "TalkerReasoner",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "events": { "endpoint": "/runs/$context.runId/events?limit=1000" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "overview", "label": "Overview" },
            { "id": "tree", "label": "Tree" },
            { "id": "transcript", "label": "Transcript" },
            { "id": "decisions", "label": "Decisions" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": ["overview", "tree", "transcript", "decisions", "agents", "events", "graph"]
      },
      "overview": {
        "type": "TalkerDetailOverview",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "tree": {
        "type": "TalkerTreeTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "transcript": {
        "type": "TranscriptView",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "decisions": {
        "type": "DecisionsView",
        "props": {
          "runId": "$context.runId",
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events",
          "sourceChildren": "$queries.children"
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId", "groupBy": "hash" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
