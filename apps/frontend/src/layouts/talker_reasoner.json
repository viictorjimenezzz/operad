{
  "algorithm": "TalkerReasoner",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "events": { "endpoint": "/runs/$context.runId/events?limit=1000" },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "agentsSummary": { "endpoint": "/runs/$context.runId/agents-summary" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "tree", "label": "Tree" },
            { "id": "transcript", "label": "Transcript" },
            { "id": "decisions", "label": "Decisions" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.agentsSummary.agents)", "condition": "$expr:count($queries.agentsSummary.agents)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" }
          ]
        },
        "children": ["tree", "transcript", "decisions", "agents", "events"]
      },
      "tree": {
        "type": "TalkerTreeTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "transcript": {
        "type": "TalkerTranscriptTab",
        "props": {
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "decisions": {
        "type": "TalkerDecisionsTab",
        "props": {
          "runId": "$context.runId",
          "sourceSummary": "$queries.summary",
          "sourceEvents": "$queries.events"
        }
      },
      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId", "groupBy": "hash" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } }
    }
  }
}
