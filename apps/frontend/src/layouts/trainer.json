{
  "algorithm": "Trainer",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "events": { "endpoint": "/runs/$context.runId/events?limit=1000" },
    "progress": {
      "endpoint": "/runs/$context.runId/progress.json",
      "stream": "/runs/$context.runId/progress.sse"
    },
    "fitness": {
      "endpoint": "/runs/$context.runId/fitness.json",
      "stream": "/runs/$context.runId/fitness.sse"
    },
    "drift": {
      "endpoint": "/runs/$context.runId/drift.json",
      "stream": "/runs/$context.runId/drift.sse"
    },
    "checkpoints": {
      "endpoint": "/runs/$context.runId/checkpoints.json",
      "stream": "/runs/$context.runId/checkpoints.sse"
    },
    "gradients": {
      "endpoint": "/runs/$context.runId/gradients.json",
      "stream": "/runs/$context.runId/gradients.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "workspace", "label": "Workspace" },
            { "id": "loss", "label": "Loss" },
            { "id": "parameters", "label": "Parameters" },
            { "id": "drift", "label": "Drift" },
            { "id": "gradients", "label": "Gradients" },
            { "id": "checkpoints", "label": "Checkpoints" },
            { "id": "progress", "label": "Progress" },
            {
              "id": "traceback",
              "label": "Traceback",
              "condition": "$queries.summary.has_traceback"
            },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": [
          "workspace",
          "loss",
          "parameters",
          "drift",
          "gradients",
          "checkpoints",
          "progress",
          "traceback",
          "agents",
          "events",
          "graph"
        ]
      },

      "workspace": {
        "type": "TrainingWorkspace",
        "props": {
          "sourceFitness": "$queries.fitness",
          "sourceCheckpoints": "$queries.checkpoints",
          "sourceDrift": "$queries.drift",
          "sourceGradients": "$queries.gradients",
          "sourceProgress": "$queries.progress",
          "sourceSummary": "$queries.summary",
          "runId": "$context.runId"
        }
      },

      "loss": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["loss-grid"]
      },
      "loss-grid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["loss-card", "lr-card"]
      },
      "loss-card": {
        "type": "PanelCard",
        "props": { "title": "loss curve", "bodyMinHeight": 300 },
        "children": ["loss-chart"]
      },
      "loss-chart": {
        "type": "TrainingLossCurve",
        "props": {
          "source": "$queries.fitness",
          "sourceCheckpoint": "$queries.checkpoints",
          "height": 280
        }
      },
      "lr-card": {
        "type": "PanelCard",
        "props": { "title": "learning rate", "bodyMinHeight": 300 },
        "children": ["lr-chart"]
      },
      "lr-chart": {
        "type": "LrScheduleCurve",
        "props": { "source": "$queries.fitness", "height": 280 }
      },

      "parameters": {
        "type": "PanelCard",
        "props": { "title": "parameter evolution" },
        "children": ["parameters-view"]
      },
      "parameters-view": {
        "type": "ParameterEvolutionMultiples",
        "props": {
          "sourceCheckpoints": "$queries.checkpoints",
          "sourceSummary": "$queries.summary"
        }
      },

      "drift": {
        "type": "PanelCard",
        "props": { "title": "prompt drift" },
        "children": ["drift-view"]
      },
      "drift-view": { "type": "DriftTimeline", "props": { "source": "$queries.drift" } },

      "gradients": {
        "type": "PanelCard",
        "props": { "title": "gradient log" },
        "children": ["gradients-view"]
      },
      "gradients-view": { "type": "GradientLog", "props": { "source": "$queries.gradients" } },

      "checkpoints": {
        "type": "PanelCard",
        "props": { "title": "checkpoints" },
        "children": ["checkpoints-view"]
      },
      "checkpoints-view": {
        "type": "CheckpointTimeline",
        "props": { "source": "$queries.checkpoints" }
      },

      "progress": {
        "type": "TrainingProgressPanel",
        "props": {
          "sourceProgress": "$queries.progress",
          "sourceEvents": "$queries.events.events"
        }
      },

      "traceback": {
        "type": "TrainingTracebackTab",
        "props": {
          "runId": "$context.runId",
          "sourceSummary": "$queries.summary"
        }
      },

      "agents": {
        "type": "AgentsTab",
        "props": { "runId": "$context.runId", "groupBy": "hash" }
      },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
