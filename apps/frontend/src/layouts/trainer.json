{
  "algorithm": "Trainer",
  "version": 1,
  "dataSources": {
    "summary": { "endpoint": "/runs/$context.runId/summary" },
    "progress": {
      "endpoint": "/runs/$context.runId/progress.json",
      "stream": "/runs/$context.runId/progress.sse"
    },
    "fitness": {
      "endpoint": "/runs/$context.runId/fitness.json",
      "stream": "/runs/$context.runId/fitness.sse"
    },
    "drift": {
      "endpoint": "/runs/$context.runId/drift.json",
      "stream": "/runs/$context.runId/drift.sse"
    },
    "checkpoints": {
      "endpoint": "/runs/$context.runId/checkpoints.json",
      "stream": "/runs/$context.runId/checkpoints.sse"
    },
    "gradients": {
      "endpoint": "/runs/$context.runId/gradients.json",
      "stream": "/runs/$context.runId/gradients.sse"
    },
    "children": { "endpoint": "/runs/$context.runId/children" },
    "graph": { "endpoint": "/graph/$context.runId" }
  },
  "spec": {
    "root": "page",
    "elements": {
      "page": {
        "type": "Tabs",
        "props": {
          "tabs": [
            { "id": "loss", "label": "Loss" },
            { "id": "drift", "label": "Drift" },
            { "id": "gradients", "label": "Gradients" },
            { "id": "checkpoints", "label": "Checkpoints" },
            { "id": "progress", "label": "Progress" },
            { "id": "agents", "label": "Agents", "badge": "$expr:count($queries.children)" },
            { "id": "events", "label": "Events", "badge": "$queries.summary.event_total" },
            { "id": "graph", "label": "Graph" }
          ]
        },
        "children": [
          "loss",
          "drift",
          "gradients",
          "checkpoints",
          "progress",
          "agents",
          "events",
          "graph"
        ]
      },

      "loss": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["lossSection"]
      },
      "lossSection": {
        "type": "PanelSection",
        "props": { "label": "Loss" },
        "children": ["lossGrid"]
      },
      "lossGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["loss-card", "lr-card"]
      },
      "loss-card": {
        "type": "PanelCard",
        "props": { "title": "loss curve", "bodyMinHeight": 260 },
        "children": ["loss"]
      },
      "loss": {
        "type": "TrainingLossCurve",
        "props": {
          "source": "$queries.fitness",
          "checkpointSource": "$queries.checkpoints",
          "height": 240
        }
      },
      "lr-card": {
        "type": "PanelCard",
        "props": { "title": "learning rate", "bodyMinHeight": 200 },
        "children": ["lr"]
      },
      "lr": {
        "type": "LrScheduleCurve",
        "props": { "source": "$queries.fitness", "height": 180 }
      },

      "drift": {
        "type": "PanelCard",
        "props": { "title": "prompt drift" },
        "children": ["drift-view"]
      },
      "drift-view": { "type": "DriftTimeline", "props": { "source": "$queries.drift" } },

      "gradients": {
        "type": "PanelCard",
        "props": { "title": "gradient log" },
        "children": ["gradients-view"]
      },
      "gradients-view": { "type": "GradientLog", "props": { "source": "$queries.gradients" } },

      "checkpoints": {
        "type": "PanelCard",
        "props": { "title": "checkpoints" },
        "children": ["checkpoints-view"]
      },
      "checkpoints-view": {
        "type": "CheckpointTimeline",
        "props": { "source": "$queries.checkpoints" }
      },

      "progress": {
        "type": "Stack",
        "props": { "gap": 16 },
        "children": ["progressGrid"]
      },
      "progressGrid": {
        "type": "PanelGrid",
        "props": { "cols": 2 },
        "children": ["meta-card", "progress-card"]
      },
      "meta-card": {
        "type": "PanelCard",
        "props": { "title": "meta" },
        "children": ["meta", "langfuse"]
      },
      "meta": { "type": "MetaList", "props": { "source": "$queries.summary" } },
      "langfuse": { "type": "LangfuseLink", "props": { "runId": "$context.runId" } },
      "progress-card": {
        "type": "PanelCard",
        "props": { "title": "training progress" },
        "children": ["progress"]
      },
      "progress": { "type": "TrainingProgress", "props": { "source": "$queries.progress" } },

      "agents": { "type": "AgentsTab", "props": { "runId": "$context.runId" } },
      "events": { "type": "EventsTab", "props": { "runId": "$context.runId" } },
      "graph": {
        "type": "PanelCard",
        "props": { "title": "agent graph" },
        "children": ["graph-view"]
      },
      "graph-view": { "type": "AgentGraph", "props": { "source": "$queries.graph" } }
    }
  }
}
